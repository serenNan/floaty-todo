{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "floaty-todo",
  "version": "0.1.0",
  "identifier": "com.serendipity.floaty-todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Floaty Todo",
        "width": 380,
        "height": 600,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
